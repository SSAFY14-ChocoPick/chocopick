<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- вң… 1) нҷҳмҳҒ мҳҒм—ӯ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutWelcome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="15dp"
        android:paddingBottom="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/chocopick_logo"
            android:contentDescription="logo"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="лЎңл”©мӨ‘..."
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            app:layout_constraintStart_toEndOf="@id/ivLogo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivLogo"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="4dp"
            android:text="мҳӨлҠҳмқҖ м–ҙл–Ө мҙҲмҪңлҰҝмқҙ лҒҢлҰ¬м„ёмҡ”?"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toEndOf="@id/ivLogo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- вң… 2) мҠӨнғ¬н”„: м№ҙл“ң мң м§Җ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStamp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"
        android:layout_marginTop="5dp"
        app:cardCornerRadius="22dp"
        app:cardBackgroundColor="@color/bg_surface"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/layoutWelcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:background="@color/bg_stamp_surface">

            <LinearLayout
                android:id="@+id/layoutStampHeaderRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tvStampSummary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="мҠӨнғ¬н”„ 0/10"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoCoupons"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:backgroundTint="@color/choco_primary"
                    android:text="мҝ нҸ°н•Ё"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_coupon"
                    app:iconPadding="6dp"
                    app:iconTint="@android:color/white"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvStamps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:overScrollMode="never"
                app:layout_constraintTop_toBottomOf="@id/layoutStampHeaderRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- вң… 3) мҠӨнҒ¬лЎӨ мҳҒм—ӯ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollHome"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_marginTop="3dp"
        app:layout_constraintTop_toBottomOf="@id/cardStamp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="3dp">

            <!-- вң… м¶”мІң м„№м…ҳ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="мҳӨлҠҳмқҳ м¶”мІң"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"/>

<!--                    <TextView-->
<!--                        android:id="@+id/btnMoreRecommend"-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:text="м „мІҙліҙкё°"-->
<!--                        android:textSize="13sp"-->
<!--                        android:textColor="@color/text_secondary"/>-->
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecommend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:overScrollMode="never"/>
            </LinearLayout>

            <!-- вң… м¶”мІң/л°°л„Ҳ кө¬л¶„м„  -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:background="@color/divider"/>

            <!-- вң… л°°л„Ҳ: м№ҙл“ң мң м§Җ + мқҙлҜём§Җк°Җ indicatorмҳҒм—ӯк№Ңм§Җ кҪү м°ЁкІҢ(мҳӨлІ„л Ҳмқҙ) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:padding="5dp">

                <!-- вң… кІ№м№ҳкё°: vpBannerк°Җ м „мІҙлҘј мұ„мҡ°кі  indicatorлҠ” мң„м—җ м–№мқҢ -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="190dp">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vpBanner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                    <LinearLayout
                        android:id="@+id/bannerIndicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_indicator_pill"/>
                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- рҹӨ– AI мұ—лҙҮ мқҙлҸҷ FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabChatbot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="AI мұ—лҙҮ"
        app:srcCompat="@drawable/ic_chat"
        app:tint="@android:color/white"
        android:backgroundTint="@color/choco_primary"

        app:elevation="0dp"
        android:elevation="0dp"
        app:pressedTranslationZ="0dp"
        android:stateListAnimator="@null"

        app:maxImageSize="38dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
