<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="0dp">

        <!-- Header: 인사 + 로그아웃 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/chocopick_logo"
                    android:contentDescription="profile"
                    android:scaleType="fitCenter"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="로딩중..."
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toEndOf="@id/ivAvatar"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnLogout"/>

                <TextView
                    android:id="@+id/tvSubGreeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="4dp"
                    android:text="오늘도 달콤한 픽업, 준비됐어요."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    app:layout_constraintStart_toEndOf="@id/ivAvatar"
                    app:layout_constraintTop_toBottomOf="@id/tvGreeting"
                    app:layout_constraintEnd_toStartOf="@id/btnLogout"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="logout"
                    android:padding="20dp"
                    app:cornerRadius="16dp"
                    android:backgroundTint="@color/bg_surface"
                    app:icon="@drawable/ic_logout"
                    app:iconTint="@color/choco_accent"
                    app:iconSize="22dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Membership -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMembership"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardProfile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvMembershipTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="내 멤버십"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tvMembershipGrade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="로딩중..."
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="@color/choco_primary"
                    app:layout_constraintTop_toBottomOf="@id/tvMembershipTitle"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tvMembershipDesc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text= "로딩중..."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    app:layout_constraintTop_toBottomOf="@id/tvMembershipGrade"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <ProgressBar
                    android:id="@+id/progressToNext"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_marginTop="14dp"
                    android:indeterminate="false"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="@color/choco_primary"
                    android:progressBackgroundTint="@color/divider"
                    app:layout_constraintTop_toBottomOf="@id/tvMembershipDesc"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:ignore="MissingClass" />

                <TextView
                    android:id="@+id/tvNextGradeHint"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="로딩중..."
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    app:layout_constraintTop_toBottomOf="@id/progressToNext"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Recent orders -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRecentOrders"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardMembership"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvRecentOrderTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="최근 주문내역"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvMoreOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전체보기"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="@color/choco_secondary"/>
                </LinearLayout>

                <!-- 최근 주문 1개 (샘플 UI) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardOrderItem1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bg_main"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tvOrderStore1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="초코픽 동탄점"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/tvOrderStatus1"/>

                        <TextView
                            android:id="@+id/tvOrderStatus1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="픽업완료"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/choco_primary"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/tvOrderMenu1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="다크초코 라떼 1 + 브라우니 1"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            app:layout_constraintTop_toBottomOf="@id/tvOrderStore1"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/tvOrderDate1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="2025.12.19"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            app:layout_constraintTop_toBottomOf="@id/tvOrderMenu1"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/tvOrderPrice1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="₩ 8,900"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            app:layout_constraintTop_toBottomOf="@id/tvOrderMenu1"
                            app:layout_constraintEnd_toEndOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 주문이 없을 때 표시용 (필요 시 visibility로 토글) -->
                <TextView
                    android:id="@+id/tvEmptyOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="아직 주문내역이 없어요. 첫 픽업을 시작해볼까요?"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Extra menu: 커피앱 느낌의 마이페이지 메뉴 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardRecentOrders"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="내 메뉴"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:id="@+id/tvMenuCoupons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="쿠폰 / 스탬프"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"/>

                <TextView
                    android:id="@+id/tvMenuFavorites"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="즐겨찾는 매장"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"/>

                <TextView
                    android:id="@+id/tvMenuPayment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="결제수단 관리"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"/>

                <TextView
                    android:id="@+id/tvMenuSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="알림 설정"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
