<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="6dp">

        <!-- ===================== -->
        <!-- 1) Profile Section (배경/테두리 제거) -->
        <!-- ===================== -->
        <LinearLayout
            android:id="@+id/sectionProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- ✅ 텍스트 영역 끝을 고정(배민/카카오 스타일) -->
                <!-- 버튼(48dp) + 간격(24dp) = 72dp -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guidelineTextEnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintGuide_end="72dp" />

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/chocopick_logo"
                    android:contentDescription="profile"
                    android:scaleType="fitCenter"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="로딩중..."
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toEndOf="@id/ivAvatar"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/guidelineTextEnd"/>

                <TextView
                    android:id="@+id/tvSubGreeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="4dp"
                    android:text="오늘도 달콤한 픽업, 준비됐어요."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    app:layout_constraintStart_toEndOf="@id/ivAvatar"
                    app:layout_constraintTop_toBottomOf="@id/tvGreeting"
                    app:layout_constraintEnd_toStartOf="@id/guidelineTextEnd"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="logout"

                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"

                    android:backgroundTint="@color/bg_surface"
                    app:cornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/divider"

                    app:icon="@drawable/ic_logout"
                    app:iconTint="@color/choco_accent"
                    app:iconSize="22dp"
                    app:iconPadding="0dp"
                    app:iconGravity="textStart"

                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

        <!-- ===================== -->
        <!-- 2) Membership Section (✅ 카드뷰 유지) -->
        <!-- ===================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMembership"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/sectionProfile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:orientation="vertical">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvMembershipTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="내 멤버십"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/tvMembershipGrade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="로딩중..."
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="@color/choco_primary"
                        app:layout_constraintTop_toBottomOf="@id/tvMembershipTitle"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/tvMembershipDesc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="로딩중..."
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        app:layout_constraintTop_toBottomOf="@id/tvMembershipGrade"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <ProgressBar
                        android:id="@+id/progressToNext"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_marginTop="14dp"
                        android:indeterminate="false"
                        android:progress="0"
                        android:max="100"
                        android:progressTint="@color/choco_primary"
                        android:progressBackgroundTint="@color/divider"
                        app:layout_constraintTop_toBottomOf="@id/tvMembershipDesc"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:ignore="MissingClass" />

                    <TextView
                        android:id="@+id/tvNextGradeHint"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="로딩중..."
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        app:layout_constraintTop_toBottomOf="@id/progressToNext"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== -->
        <!-- 3) Recent Orders Section (✅ 카드뷰 유지 + 높이 고정) -->
        <!-- ===================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRecentOrders"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardMembership"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/sectionRecentOrders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvRecentOrderTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="최근 주문내역"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvMoreOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전체보기"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="@color/choco_secondary"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/divider"/>

                <LinearLayout
                    android:id="@+id/containerHasOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/orderItem1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="12dp"
                        android:paddingBottom="0dp">

                        <TextView
                            android:id="@+id/tvOrderStore1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="초코픽 동탄점"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/tvOrderStatus1"/>

                        <TextView
                            android:id="@+id/tvOrderStatus1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="픽업완료"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/choco_primary"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/tvOrderMenu1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="다크초코 라떼 1 + 브라우니 1"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            app:layout_constraintTop_toBottomOf="@id/tvOrderStore1"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/tvOrderDate1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="2025.12.19"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            app:layout_constraintTop_toBottomOf="@id/tvOrderMenu1"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/tvOrderPrice1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="₩ 8,900"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            app:layout_constraintTop_toBottomOf="@id/tvOrderMenu1"
                            app:layout_constraintEnd_toEndOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvEmptyOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="아직 주문내역이 없어요. 첫 픽업을 시작해볼까요?"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== -->
        <!-- 4) Menu Section (배경/테두리 제거) -->
        <!-- ===================== -->
        <LinearLayout
            android:id="@+id/sectionMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:padding="3dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardRecentOrders"
            app:layout_constraintVertical_bias="0.0">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내 메뉴"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="5dp"/>

            <TextView
                android:id="@+id/tvMenuCoupons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="쿠폰 / 스탬프"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <TextView
                android:id="@+id/tvMenuFavorites"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="즐겨찾는 매장"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <TextView
                android:id="@+id/tvMenuSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="알림 설정"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
