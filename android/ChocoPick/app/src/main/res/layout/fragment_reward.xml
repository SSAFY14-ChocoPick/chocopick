<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true"
    android:clipToPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ===================== -->
        <!-- Header (플랫) -->
        <!-- ===================== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_previous"
                android:contentDescription="back"
                app:tint="@color/text_primary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="쿠폰 / 스탬프"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/dividerHeader"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ===================== -->
        <!-- 핵심: Membership + Stamp (여기만 카드 유지) -->
        <!-- ===================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStamps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/bg_surface"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/dividerHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:orientation="vertical">

                <!-- 내 멤버십 -->
                <TextView
                    android:id="@+id/tvSection1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="내 멤버십"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:id="@+id/tvTier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="멤버십: -"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:id="@+id/tvTierBenefit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="이번 달 혜택: -"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/divider"/>

                <!-- 스탬프 -->
                <TextView
                    android:id="@+id/tvSection2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="스탬프"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:id="@+id/tvStampCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="현재 스탬프: -"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressStamp"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="10dp"
                    app:trackCornerRadius="8dp"
                    app:indicatorColor="@color/choco_primary"
                    app:trackColor="@color/divider"
                    android:progress="0"/>

                <TextView
                    android:id="@+id/tvStampHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="10개 모으면 아메리카노 쿠폰 1장 발행 가능해요."
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIssueAmericano"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="아메리카노 쿠폰 발행 (스탬프 10개)"
                    android:textColor="@color/bg_surface"
                    android:backgroundTint="@color/choco_primary"
                    app:cornerRadius="16dp"
                    android:enabled="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <TextView
                    android:id="@+id/tvAmericanoCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="보유 아메리카노 쿠폰: -장"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUseCoupon"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="아메리카노 쿠폰 사용"
                    android:textColor="@color/bg_surface"
                    android:backgroundTint="@color/choco_primary"
                    app:cornerRadius="16dp"
                    android:enabled="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <TextView
                    android:id="@+id/tvUseHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="매장 방문 후 직원이 ‘사용’ 버튼을 눌러 처리해요."
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== -->
        <!-- 멤버십 안내 (플랫 섹션) -->
        <!-- ===================== -->
        <TextView
            android:id="@+id/tvGuideTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="멤버십 안내"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="18dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardStamps"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvGuideBody"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="• 멤버십 등급은 BRONZE / SILVER / GOLD로 구성돼요.\n• 주문 누적 횟수에 따라 자동으로 승급돼요.\n• 등급별 이번 달 혜택은 ‘내 멤버십’ 영역에서 확인할 수 있어요.\n\n[등급별 혜택]\n- BRONZE: 롯데 아몬드 초코볼 46g 증정\n- SILVER: 밀카 요거트 초콜릿 100g 증정\n- GOLD: 몰티져스 밀크 버켓 초콜릿 465g 증정\n\n※ 등급 혜택은 매장 방문 시 직원 확인 후 제공돼요.\n※ 재고 상황에 따라 동일 가격대 상품으로 대체될 수 있어요."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvGuideTitle" />

        <View
            android:id="@+id/dividerGuide"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/tvGuideBody"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ===================== -->
        <!-- 적립 / 사용 안내 (플랫 섹션) -->
        <!-- ===================== -->
        <TextView
            android:id="@+id/tvRulesTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="적립 / 사용 안내"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintTop_toBottomOf="@id/dividerGuide"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvRules"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="18dp"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp"
            android:text="• 주문 완료 시 스탬프가 적립돼요.\n• 적립 기준: 상품 1개(수량 1개)당 스탬프 1개\n• 스탬프 10개를 모으면 아메리카노 쿠폰 1장이 발행돼요.\n• 발행 시: 스탬프 -10, 아메리카노 쿠폰 +1\n• 아메리카노 쿠폰은 모든 ChocoPick 제휴 매장에서 사용 가능해요.\n• 쿠폰 사용 시, 매장 방문 후 직원이 ‘사용’ 버튼을 눌러 소진 처리해요.\n• 쿠폰은 서비스 아메리카노 1잔으로 제공돼요."
            app:layout_constraintTop_toBottomOf="@id/tvRulesTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 마지막 여백 -->
        <View
            android:layout_width="0dp"
            android:layout_height="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvRules"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
